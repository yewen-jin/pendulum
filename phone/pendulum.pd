#N canvas 0 0 620 500 12;
#X text 10 10 pendulum -- MobMuPlat OSC router;
#X text 10 25 Routes widget values to [s toNetwork] for MobMuPlat UDP output.;
#X text 10 40 Configure destination IP and port in MobMuPlat Settings -> Network.;
#X obj 10 90 r /phone/panic;
#X obj 10 120 t b;
#X msg 10 150 /phone/panic;
#X obj 10 180 s toNetwork;
#X connect 3 0 4 0;
#X connect 4 0 5 0;
#X connect 5 0 6 0;
#X obj 160 90 r /phone/mode;
#X msg 160 120 /phone/mode $1;
#X obj 160 150 s toNetwork;
#X connect 7 0 8 0;
#X connect 8 0 9 0;
#X obj 310 90 r /phone/intensity;
#X msg 310 120 /phone/intensity $1;
#X obj 310 150 s toNetwork;
#X connect 10 0 11 0;
#X connect 11 0 12 0;
#X obj 10 250 r /phone/x;
#X msg 10 280 /phone/x $1;
#X obj 10 310 s toNetwork;
#X connect 13 0 14 0;
#X connect 14 0 15 0;
#X obj 160 250 r /phone/y;
#X msg 160 280 /phone/y $1;
#X obj 160 310 s toNetwork;
#X connect 16 0 17 0;
#X connect 17 0 18 0;
